meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "test@example.com",
    "password": "Password123!"
  }
}

script:post-response {
  const data = res.getBody();
  if (data.accessToken) {
    bru.setEnvVar("accessToken", data.accessToken);
  }
}
