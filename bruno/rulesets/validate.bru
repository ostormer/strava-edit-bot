meta {
  name: Validate Ruleset
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/api/rulesets/validate
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "filter": {
      "type": "and",
      "conditions": [
        {
          "type": "check",
          "property": "sport_type",
          "operator": "in",
          "value": ["Run"]
        }
      ]
    },
    "effect": {
      "name": "Morning {sport_type}"
    }
  }
}
